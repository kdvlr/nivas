# Copy to .env and fill in. Everything is optional — features degrade gracefully
# until their credentials are provided via this file or the Setup screen.

# Timezone for the dashboard
TZ=America/New_York

# --- Gemini (recipe standardization fallback) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Apple iCloud (Reminders sync via pyicloud) ---
ICLOUD_USERNAME=
ICLOUD_PASSWORD=
# Name of the Reminders list used for the shopping list
ICLOUD_SHOPPING_LIST=Shopping

# --- Amazon Alexa (lists sync via alexapy) ---
AMAZON_EMAIL=
AMAZON_PASSWORD=
# TOTP secret from Amazon 2FA app setup (recommended; avoids manual OTP prompts)
AMAZON_OTP_SECRET=
AMAZON_URL=amazon.com

# --- Setup screen PIN ---
# If set, the Setup tab asks for this PIN (keeps kids out of settings).
# Forgot it? Just edit this value and restart: docker compose restart
SETUP_PIN=

# --- Server ---
# Where SQLite DB + integration session files live (docker volume mounts this)
DATA_DIR=./data
# Public base URL of the dashboard, used for the Google OAuth redirect.
# Must match an authorized redirect URI on your OAuth client:
#   {BASE_URL}/api/calendar/auth/callback
BASE_URL=http://localhost:8000
